# Environment variables - NEVER commit these
.env
.env.local
.env.*.local
.env.backup
main.tf

.claude/

# Ad-hoc smoke tests, debugging scripts, exploratory work — anything
# that runs but isn't part of the shipped product. Not committed.
experiments/
# The shipped Space Experiment lifecycle happens to share that name; keep its
# service package while continuing to ignore root/ad-hoc experiment folders.
!services/cowork_agent/experiments/
!services/cowork_agent/experiments/*.py

