{
  "name": "openclaw",
  "binary": "openclaw",
  "home_dir": "~/.openclaw",
  "env_file": "~/.openclaw/.env",
  "config_file": "~/.openclaw/openclaw.json",
  "agents_dir": "~/.openclaw/agents",
  "workspace_dir": "~/.openclaw/workspace",
  "provisioning_log": "~/.openclaw/bridge-provisioning.log",
  "cwd": "/home/coder",
  "cli_timeout_seconds": 30,
  "api": {
    "url_env": "OPENCLAW_API_URL",
    "url_default": "http://127.0.0.1:18789/v1/chat/completions",
    "token_env": "OPENCLAW_GATEWAY_TOKEN",
    "token_default": "xo-cowork",
    "model_env": "OPENCLAW_MODEL",
    "model_default": "openclaw/default",
    "session_header": "x-openclaw-session-key"
  },
  "model_prefix": "openclaw",
  "model_capabilities": {
    "function_calling": true,
    "vision": false,
    "reasoning": true,
    "json_output": true,
    "max_context": 200000,
    "max_output": 16384
  },
  "commands": {
    "config_set":       ["{binary}", "config", "set", "{path}", "{value}"],
    "config_set_batch": ["{binary}", "config", "set", "--batch-json", "{batch_json}"],
    "models_set":       ["{binary}", "models", "set", "{model}"],
    "plugin_enable":    ["{binary}", "config", "set", "plugins.entries.{plugin}.enabled", "true"]
  },
  "providers": {
    "anthropic": {
      "env_key": "ANTHROPIC_API_KEY",
      "commands": [
        {"template": "models_set", "params": {"model": "anthropic/claude-opus-4.6"}}
      ]
    },
    "openai": {
      "env_key": "OPENAI_API_KEY",
      "commands": [
        {"template": "models_set", "params": {"model": "openai/gpt-5.4"}}
      ]
    }
  },
  "channels": {
    "slack": {
      "fields": {
        "bot_token": "SLACK_BOT_TOKEN",
        "app_token": "SLACK_APP_TOKEN"
      },
      "config_batch": [
        {"path": "channels.slack.mode",        "value": "socket"},
        {"path": "channels.slack.enabled",     "value": true},
        {"path": "channels.slack.dmPolicy",    "value": "open"},
        {"path": "channels.slack.allowFrom",   "value": ["*"]},
        {"path": "channels.slack.groupPolicy", "value": "open"}
      ],
      "post_commands": [
        {"template": "plugin_enable", "params": {"plugin": "slack"}}
      ]
    },
    "telegram": {
      "fields": {
        "token": "TELEGRAM_BOT_TOKEN"
      },
      "config_batch": [
        {"path": "channels.telegram.enabled",     "value": true},
        {"path": "channels.telegram.dmPolicy",    "value": "open"},
        {"path": "channels.telegram.allowFrom",   "value": ["*"]},
        {"path": "channels.telegram.groupPolicy", "value": "allowlist"},
        {"path": "channels.telegram.streaming",   "value": {"mode": "partial"}}
      ],
      "post_commands": [
        {"template": "plugin_enable", "params": {"plugin": "telegram"}}
      ]
    },
    "discord": {
      "fields": {
        "token": "DISCORD_BOT_TOKEN"
      },
      "config_batch": [
        {"path": "channels.discord.enabled",     "value": true},
        {"path": "channels.discord.groupPolicy", "value": "open"},
        {"path": "channels.discord.streaming",   "value": {"mode": "partial"}},
        {"path": "channels.discord.dmPolicy",    "value": "open"},
        {"path": "channels.discord.allowFrom",   "value": ["*"]},
        {"path": "channels.discord.dm",          "value": {"enabled": true}}
      ],
      "post_commands": [
        {"template": "plugin_enable", "params": {"plugin": "discord"}}
      ]
    }
  }
}
