{
  "name": "codex",
  "binary": "codex",
  "home_dir": "~/.codex",
  "env_file": "~/.codex/.env",
  "config_file": "~/.codex/config.toml",
  "agents_dir": "~/.codex/sessions",
  "workspace_dir": "~/xo-projects",
  "provisioning_log": "~/.codex/provisioning.log",
  "precreate_home_for_skills": true,
  "cwd": "~",
  "cli_timeout_seconds": 300,
  "api": {
    "session_header": ""
  },
  "model_prefix": "codex",
  "model_capabilities": {
    "function_calling": true,
    "vision": true,
    "reasoning": true,
    "json_output": true,
    "max_context": 256000,
    "max_output": 16384
  },
  "flags": {
    "json": true,
    "skip_git_repo_check": true,
    "dangerously_bypass_approvals_and_sandbox": true
  }
}
