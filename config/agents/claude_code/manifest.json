{
  "name": "claude_code",
  "binary": "claude",
  "home_dir": "~/.claude",
  "env_file": "~/.claude/.env",
  "config_file": "~/.claude/settings.json",
  "agents_dir": "~/.claude/projects",
  "workspace_dir": "~/xo-projects",
  "provisioning_log": "~/.claude/provisioning.log",
  "precreate_home_for_skills": true,
  "cwd": "~",
  "cli_timeout_seconds": 300,
  "api": {
    "session_header": ""
  },
  "model_prefix": "claude_code",
  "model_capabilities": {
    "function_calling": true,
    "vision": true,
    "reasoning": true,
    "json_output": true,
    "max_context": 200000,
    "max_output": 16384
  },
  "skills": {
    "default": null,
    "code-writer": "/code-writer",
    "reviewer": "/reviewer",
    "debugger": "/debugger",
    "agno-agentic-backend": "/agno-agentic-backend"
  },
  "flags": {
    "dangerously_skip_permissions": true,
    "output_format": "stream-json"
  },
  "providers": {
    "openrouter": {
      "settings_env": {
        "ANTHROPIC_BASE_URL": "https://openrouter.ai/api",
        "ANTHROPIC_AUTH_TOKEN": "{api_key}",
        "ANTHROPIC_API_KEY": ""
      }
    }
  }
}