# XO Cowork API Environment Variables

# Server Configuration
HOST=0.0.0.0
PORT=5002
STAGE=beta                      # beta (default linux paths) | local (auto-resolve local paths)

# External Chat API URL (xo-swarm-api)
CHAT_API_BASE_URL=https://api-swarm-beta.xo.builders

# XO backend browser-auth flow endpoints
XO_AUTH_START_PATH=/auth/browser/start
XO_AUTH_STATUS_PATH=/auth/browser/status
XO_AUTH_CONSUME_PATH=/auth/browser/consume
XO_GET_USER_ID_PATH=/get-user-id
# Optional consume values:
# - used as fallback if /xo-auth/consume body omits them
# - if both are set, app attempts auto-consume once at startup
# XO_AUTH_SESSION_ID=your-auth-session-id
# XO_POLL_TOKEN=your-poll-token
# Optional long-lived auth (Clerk user API key). Used when no session from consume.
# Requires xo-swarm-api to accept and verify Clerk API keys (Bearer ak_xxx).
# XO_API_KEY=ak_xxxxxxxx

# Claude Code CLI Configuration
CLAUDE_CLI_PATH=claude          # Path to claude CLI (default: assumes in PATH)
CLAUDE_TIMEOUT=300              # Timeout in seconds (default: 5 minutes)
CLAUDE_PERMISSION_MODE=bypassPermissions  # Claude permission mode
AI_WORKSPACE_ROOT=/home/coder             # Working directory and allowed --add-dir (beta default)
# User-facing projects root surfaced by /api/config/workspace and used by the
# frontend sidebar + onboarding for new project creation. Created on first read
# if it does not exist. Default: ~/xo-projects
XO_PROJECTS_ROOT=/home/coder/xo-projects
# Codex CLI Configuration
CODEX_CLI_PATH=codex            # Path to codex CLI (default: assumes in PATH)
CODEX_TIMEOUT=300               # Timeout in seconds (default: inherits CLAUDE_TIMEOUT)
# Runtime provider selection
AI_PROVIDER=claude              # claude | codex
# Optional provider credentials (CLI may also use prior login/session)
# ANTHROPIC_API_KEY=your-anthropic-api-key
# OPENAI_API_KEY=your-openai-api-key
# CODEX_API_KEY=your-codex-api-key   # Supported by codex exec for per-run auth
# Claude-native behavior is configured via:
# - CLAUDE.md (project memory/instructions)
# - .claude/skills/*/SKILL.md (task-specific skills)
# Codex-native behavior is configured via:
# - AGENTS.md (project memory/instructions)
# - .agents/skills/*/SKILL.md (task-specific skills)
# Composio integrations (Gmail, Stripe, Notion, Google Calendar, Supabase,
# DigitalOcean, YouTube, Miro, Canva — see services/composio_service.py).
# Get the API key from https://platform.composio.dev/settings.
# COMPOSIO_API_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Per-toolkit auth_config_id values (created in the Composio dashboard).
# Leave blank for toolkits you haven't configured yet — the router will
# surface them as "not configured" instead of failing.
# COMPOSIO_AUTH_CONFIG_GMAIL=ac_xxx
# COMPOSIO_AUTH_CONFIG_GOOGLECALENDAR=ac_xxx
# COMPOSIO_AUTH_CONFIG_NOTION=ac_xxx
# COMPOSIO_AUTH_CONFIG_STRIPE_OAUTH=ac_xxx
# COMPOSIO_AUTH_CONFIG_STRIPE_APIKEY=ac_xxx
# COMPOSIO_AUTH_CONFIG_SUPABASE=ac_xxx
# COMPOSIO_AUTH_CONFIG_DIGITALOCEAN=ac_xxx
# COMPOSIO_AUTH_CONFIG_YOUTUBE=ac_xxx
# COMPOSIO_AUTH_CONFIG_MIRO=ac_xxx
# COMPOSIO_AUTH_CONFIG_CANVA=ac_xxx
#
# OAuth callback URL Composio will redirect to after the user authorizes.
# Must be reachable from the user's browser. Default matches the local
# uvicorn server on port 5002.
# COMPOSIO_CALLBACK_URL=http://127.0.0.1:5002/api/connectors/composio/callback
#
# Where local Composio state is cached. Composio is source of truth; this
# is a per-machine cache so the integrations grid doesn't round-trip on
# every render. See docs/composio-xo-swarm-api-migration.md.
# COMPOSIO_DB_PATH=~/.xo-cowork/composio.db
#
# --- Multi-tenant Composio (per-user isolation) ---
# Off by default (single shared "default_user"). When 1: each user's Composio
# connections, Tool Router session, and action prefs are isolated by their XO
# user_id. Identity is carried as a backend-minted opaque session id — see
# services/session_identity.py and services/composio_identity.py.
#   - With the flag ON, /api/connectors/composio/* REQUIRE a valid session
#     bearer (401 without one). Only enable once the frontend/platform sends
#     `Authorization: Bearer <session_id>` (mint via POST /xo-auth/session).
#   - COMPOSIO_STATE_SECRET signs the user-scoped agent proxy token; it is
#     REQUIRED when the flag is on and must be stable across workers.
#   - The session store is in-process → single worker only (the launch-script
#     default). For --workers>1, swap it for a shared store or make the session
#     token a signed, self-verifying value like the proxy token.
# COMPOSIO_MULTI_TENANT=0
# COMPOSIO_STATE_SECRET=        # e.g. openssl rand -hex 32
# XO_SESSION_TTL=43200          # optional, seconds; default 12h
#
# Single-instance real identity: when 1, resolve this backend's one real XO user
# from the XO credential (XO_API_KEY / consumed token) at startup and attribute
# Composio calls to it instead of the generic "default_user" sentinel. Independent
# of COMPOSIO_MULTI_TENANT (that's the many-user, per-request-bearer path). Reads
# existing auth state only — never mutates it. See services/instance_identity.py.
# XO_RESOLVE_INSTANCE_USER=0

# Vercel OAuth connector
# Must match exactly the redirect_uri registered in the Vercel OAuth app.
# Default: http://127.0.0.1/callback  (matches the vercel_client entry in mcp-tokens.json)
# VERCEL_OAUTH_REDIRECT_URI=http://127.0.0.1/callback

# OpenClaw local gateway (spawned by config/agents/openclaw/agent.sh on port 18789)
OPENCLAW_API_URL=http://127.0.0.1:18789/v1/chat/completions
OPENCLAW_MODEL=openclaw/default
# OPENCLAW_GATEWAY_TOKEN is already defined elsewhere; reused by cowork_agent
# for outbound Bearer auth. Default when unset: "xo-cowork".

# Hermes local gateway (started by `hermes gateway run` on port 8642).
# Requires API_SERVER_ENABLED=true and API_SERVER_KEY set in ~/.hermes/.env;
# the bearer token used here must match that API_SERVER_KEY. Hermes owns
# session history in ~/.hermes/state.db — xo-cowork sends the session id via
# X-Hermes-Session-Id and stays stateless.
# HERMES_API_URL=http://127.0.0.1:8642/v1/chat/completions
# HERMES_MODEL=hermes-agent
# API_SERVER_KEY=change-me-local-dev

# cowork_agent picks its binary, paths, and CLI recipes from the manifest
# at config/agents/<name>/manifest.json. The active manifest is resolved
# from AGENT_NAME (runtime override) → DEFAULT_AGENT (baseline) → single
# manifest auto-pick. Set AGENT_NAME at runtime to switch backends without
# editing the .env baseline.
# DEFAULT_AGENT=openclaw
AGENT_NAME=openclaw

# ──────────────────────────────────────────────────────────────────────────
# xo-projects backup & restore (POST /api/xo-projects-sync/...)
# ──────────────────────────────────────────────────────────────────────────
# Populated by POST /api/xo-projects-sync/setup — you usually don't edit
# these by hand. They're written here so dotenv picks them up after a
# server restart and so a workspace can be re-provisioned from this file.
#
# BACKUP_REPO_NAME — name of the private GitHub repo that holds the
#   encrypted snapshots (one repo for all projects). Owner is
#   discovered from the GitHub token at request time.
# BACKUP_REPO_NAME=xo-projects-backup
#
# BACKUP_PASSWORD — symmetric encryption passphrase used by gpg.
#   Required on every backup AND every restore — keep it safe; without
#   it your backups are unrecoverable.
# BACKUP_PASSWORD=change-me-to-a-strong-passphrase
#
# GITHUB_PAT — fallback GitHub token (used when the cowork UI's GitHub
#   connector hasn't been set up). Needs `repo` scope to create + push
#   to the private backup repo. The connector token takes precedence
#   when both are present.
# GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Requires `gnupg` (provides gpg + gpg-agent) installed on the host.
# Apt: sudo apt-get install -y gnupg
